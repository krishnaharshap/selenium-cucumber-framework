<?xml version="1.0" encoding="UTF-8"?>
<extentreports>
    <configuration>
        <!-- Report theme: STANDARD or DARK -->
        <theme>STANDARD</theme>

        <!-- Document encoding: UTF-8, UTF-16 -->
        <encoding>UTF-8</encoding>

        <!-- Protocol: HTTP, HTTPS -->
        <protocol>HTTPS</protocol>

        <!-- Title of the report -->
        <documentTitle>E2E Test Automation Report</documentTitle>

        <!-- Name of the report -->
        <reportName>Test Execution Report</reportName>

        <!-- Timestamp format -->
        <timeStampFormat>MMM dd, yyyy HH:mm:ss</timeStampFormat>

        <!-- Custom CSS -->
        <css>
            .r-img { width: 100%; }
        </css>

        <!-- Custom JavaScript -->
        <js>
        </js>
    </configuration>
</extentreports>